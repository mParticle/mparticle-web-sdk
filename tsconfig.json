{
    "extends": "./node_modules/gts/tsconfig-google.json",
    "compilerOptions": {
        "declaration": false,
        "lib": ["es5", "es6", "dom"],
        "rootDir": ".",
        "outDir": "build",
        "sourceMap": true,
        "skipLibCheck": true,
        "noImplicitAny": false,
        "strictNullChecks": false,
        "target": "es5",
        "baseUrl": ".",
        "moduleResolution": "Node",
        "resolveJsonModule": true,
        // this is required for importing the 'fetch-mock/esm/client' module, otherwise it errors
        "allowSyntheticDefaultImports": true,
        "paths": {
            "@mparticle/web-sdk": ["src/public-types.ts"],
            "@mparticle/web-sdk/internal": ["src/internal-types.ts"]
        }
    },
    "include": ["src/**/*.ts", "test/**/*.ts"],
    "exclude": ["test/fixtures/**/*.ts"]
}
